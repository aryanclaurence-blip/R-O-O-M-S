<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Linked Models" Height="350" Width="450"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI"
        ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True">
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="Select the linked models you want to process:" Margin="0,0,0,12" FontWeight="SemiBold"/>
        
        <ListBox Grid.Row="1" x:Name="link_listbox" BorderBrush="#D9D9D9">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="4"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,16">
            <Button x:Name="btn_select_all" Content="Select All" Width="80" Height="24" Margin="0,0,8,0"/>
            <Button x:Name="btn_clear_all" Content="Clear All" Width="80" Height="24"/>
        </StackPanel>
        
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btn_ok" Content="OK" Width="80" Height="26" Margin="0,0,8,0" IsDefault="True"/>
            <Button x:Name="btn_cancel" Content="Cancel" Width="80" Height="26" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
