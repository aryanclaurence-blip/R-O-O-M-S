<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Room Dimension Manager" 
        Height="800" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6F8"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <!-- Enterprise Styling -->
        <Style TargetType="TextBlock" x:Key="HeaderStyle">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="SubHeaderStyle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#666666"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="StepHeaderStyle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="#0066CC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5,0"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F9F9F9"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E0E0E0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Controls -->
            <RowDefinition Height="Auto"/> <!-- Run & Progress -->
            <RowDefinition Height="*"/>    <!-- Results Grid -->
            <RowDefinition Height="Auto"/> <!-- Reports -->
            <RowDefinition Height="Auto"/> <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Room Dimension Manager" Style="{StaticResource HeaderStyle}"/>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <TextBlock Text="{Binding ProjectName}" Style="{StaticResource SubHeaderStyle}" Margin="0,0,15,0"/>
                <TextBlock Text="{Binding ModelName}" Style="{StaticResource SubHeaderStyle}" Margin="0,0,15,0"/>
                <TextBlock Text="{Binding RevitVersion}" Style="{StaticResource SubHeaderStyle}"/>
            </StackPanel>
        </StackPanel>

        <!-- Controls -->
        <Border Grid.Row="1" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Length Parameter Selection" Style="{StaticResource StepHeaderStyle}"/>
                    <ComboBox ItemsSource="{Binding AvailableParameters}" SelectedItem="{Binding SelectedLengthParameter}" Height="30" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Width Parameter Selection" Style="{StaticResource StepHeaderStyle}"/>
                    <ComboBox ItemsSource="{Binding AvailableParameters}" SelectedItem="{Binding SelectedWidthParameter}" Height="30"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Margin="10,0,10,0">
                    <TextBlock Text="Processing Scope" Style="{StaticResource StepHeaderStyle}"/>
                    <RadioButton Content="Entire Project" IsChecked="{Binding ScopeEntireProject}" Margin="0,0,0,5"/>
                    <RadioButton Content="Current View" IsChecked="{Binding ScopeCurrentView}" Margin="0,0,0,5"/>
                    <RadioButton Content="Selected Rooms" IsChecked="{Binding ScopeSelectedRooms}" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Tolerance" Style="{StaticResource StepHeaderStyle}"/>
                    <TextBox Text="{Binding Tolerance}" Height="25" VerticalContentAlignment="Center" Padding="5,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                    <TextBlock Text="Operation" Style="{StaticResource StepHeaderStyle}"/>
                    <RadioButton Content="Set Room Dimensions" IsChecked="{Binding OperationSetDimensions}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <RadioButton Content="Cross Check Dimensions" IsChecked="{Binding OperationCrossCheck}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Run & Progress -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="RUN" Command="{Binding RunCommand}" Style="{StaticResource PrimaryButton}" Width="150" Height="40" FontSize="16"/>
            
            <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center" Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding ProgressMessage}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <ProgressBar Minimum="0" Maximum="{Binding TotalProgressItems}" Value="{Binding CurrentProgressValue}" Height="15"/>
            </StackPanel>
        </Grid>

        <!-- Results Grid -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding ResultsList}" Margin="0,0,0,15">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Room Number" Binding="{Binding RoomNumber}" Width="100"/>
                <DataGridTextColumn Header="Room Name" Binding="{Binding RoomName}" Width="*"/>
                <DataGridTextColumn Header="Classification" Binding="{Binding Classification}" Width="120"/>
                <DataGridTextColumn Header="Calculated L" Binding="{Binding CalculatedLength}" Width="90"/>
                <DataGridTextColumn Header="Calculated W" Binding="{Binding CalculatedWidth}" Width="90"/>
                <DataGridTextColumn Header="Stored L" Binding="{Binding StoredLength}" Width="90"/>
                <DataGridTextColumn Header="Stored W" Binding="{Binding StoredWidth}" Width="90"/>
                <DataGridTextColumn Header="Result" Binding="{Binding Result}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Reports -->
        <Border Grid.Row="4" Background="#E9ECEF" Padding="10" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Reports:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,15,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Export CSV" Command="{Binding ExportCsvCommand}" Style="{StaticResource SecondaryButton}"/>
                    <Button Content="Export Excel" Command="{Binding ExportExcelCommand}" Style="{StaticResource SecondaryButton}"/>
                    <Button Content="Export JSON" Command="{Binding ExportJsonCommand}" Style="{StaticResource SecondaryButton}"/>
                    <Button Content="Open Report Folder" Command="{Binding OpenFolderCommand}" Style="{StaticResource SecondaryButton}"/>
                    <Button Content="Copy Summary" Command="{Binding CopySummaryCommand}" Style="{StaticResource SecondaryButton}"/>
                    <Button Content="Settings" Command="{Binding SettingsCommand}" Style="{StaticResource SecondaryButton}"/>
                    <Button Content="Help" Command="{Binding HelpCommand}" Style="{StaticResource SecondaryButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <StatusBar Grid.Row="5" Background="Transparent">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" FontStyle="Italic" Foreground="DimGray"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
