<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Room Dimension Manager" Height="700" Width="1050"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI">
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <StackPanel Grid.Row="0" Margin="0,0,0,14">
      <TextBlock Text="Room Dimension Manager" FontSize="25" FontWeight="SemiBold"/>
      <TextBlock x:Name="document_label" Foreground="DimGray"/>
    </StackPanel>
    <Grid Grid.Row="1" Margin="0,0,0,14">
      <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Margin="0,0,12,0">
        <TextBlock Text="Length Parameter (X)" FontWeight="Bold"/>
        <ComboBox x:Name="length_parameter" Margin="0,5,0,10"/>
        <TextBlock Text="Width Parameter (Y)" FontWeight="Bold"/>
        <ComboBox x:Name="width_parameter" Margin="0,5,0,0"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Margin="6,0,12,0">
        <TextBlock Text="Processing Scope" FontWeight="Bold"/>
        <ComboBox x:Name="scope" SelectedIndex="0" Margin="0,5,0,10"><ComboBoxItem Content="Entire Project"/><ComboBoxItem Content="Selected Rooms"/></ComboBox>
        <TextBlock Text="Tolerance (ft)" FontWeight="Bold"/>
        <TextBox x:Name="tolerance" Text="0.01" Margin="0,5,0,0"/>
      </StackPanel>
      <StackPanel Grid.Column="2" Margin="6,0,0,0">
        <TextBlock Text="Operation" FontWeight="Bold"/>
        <ComboBox x:Name="operation" SelectedIndex="0" Margin="0,5,0,0"><ComboBoxItem Content="Cross Check"/><ComboBoxItem Content="Set Room Dimensions"/></ComboBox>
      </StackPanel>
    </Grid>
    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
      <Button x:Name="run_button" Content="Run" Width="130" Height="32" Margin="0,0,8,0"/>
      <Button x:Name="export_button" Content="Export CSV" Width="130" Height="32" Margin="0,0,8,0"/>
      <Button x:Name="settings_button" Content="Settings" Width="100" Height="32" Margin="0,0,8,0"/>
      <Button x:Name="help_button" Content="Help" Width="100" Height="32"/>
    </StackPanel>
    <DataGrid Grid.Row="3" x:Name="results_grid" AutoGenerateColumns="False" IsReadOnly="True">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Number" Binding="{Binding RoomNumber}" Width="90"/>
        <DataGridTextColumn Header="Name" Binding="{Binding RoomName}" Width="*"/>
        <DataGridTextColumn Header="Shape" Binding="{Binding Classification}" Width="120"/>
        <DataGridTextColumn Header="Length (ft)" Binding="{Binding CalculatedLength}" Width="100"/>
        <DataGridTextColumn Header="Width (ft)" Binding="{Binding CalculatedWidth}" Width="100"/>
        <DataGridTextColumn Header="Stored L" Binding="{Binding StoredLength}" Width="100"/>
        <DataGridTextColumn Header="Stored W" Binding="{Binding StoredWidth}" Width="100"/>
        <DataGridTextColumn Header="Result" Binding="{Binding Result}" Width="140"/>
      </DataGrid.Columns>
    </DataGrid>
    <TextBlock Grid.Row="4" x:Name="status" Margin="0,10,0,0" Foreground="DimGray"/>
  </Grid>
</Window>
