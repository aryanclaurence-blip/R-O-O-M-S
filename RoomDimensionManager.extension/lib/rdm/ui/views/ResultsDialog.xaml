<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cross Check Results" 
        Height="550" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="#F4F4F4"
        FontFamily="Segoe UI">
    <Window.Resources>
        <!-- Enterprise Styling -->
        <Style TargetType="TextBlock" x:Key="HeaderStyle">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#101010"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="MetricStyle">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="#0066CC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Metrics Box -->
            <RowDefinition Height="*"/>    <!-- Resolution Options -->
            <RowDefinition Height="Auto"/> <!-- Export Area -->
            <RowDefinition Height="Auto"/> <!-- Bottom Buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Cross Check Completed" Style="{StaticResource HeaderStyle}" Margin="0,0,0,15"/>

        <!-- Metrics Box -->
        <Border Grid.Row="1" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding TotalRoomsText}" Style="{StaticResource MetricStyle}" FontWeight="Bold"/>
                    <TextBlock Text="{Binding PassText}" Style="{StaticResource MetricStyle}" Foreground="#28A745"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding FailText}" Style="{StaticResource MetricStyle}" Foreground="#DC3545"/>
                    <TextBlock Text="{Binding ReviewText}" Style="{StaticResource MetricStyle}" Foreground="#FFC107"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Resolution Options -->
        <StackPanel Grid.Row="2" Margin="0,20,0,0">
            <TextBlock Text="Choose what to do with mismatching rooms." FontWeight="SemiBold" FontSize="16" Margin="0,0,0,15"/>
            
            <RadioButton Content="Highlight Mismatches (Graphics Override)" IsChecked="{Binding ActionHighlight}" Margin="0,0,0,10" FontSize="14"/>
            <TextBlock Text="Applies temporary colors in active view. Does not alter element data." Margin="20,0,0,15" Foreground="Gray"/>
            
            <RadioButton Content="Overwrite Parameter Values" IsChecked="{Binding ActionOverwrite}" Margin="0,0,0,10" FontSize="14"/>
            <TextBlock Text="Replaces stored parameters with calculated geometry values." Margin="20,0,0,15" Foreground="Gray"/>
            
            <RadioButton Content="Cancel (No Action)" IsChecked="{Binding ActionCancel}" Margin="0,0,0,10" FontSize="14"/>
        </StackPanel>

        <!-- Export Area -->
        <Border Grid.Row="3" Background="#E9ECEF" Padding="10" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Export CSV" Command="{Binding ExportCsvCommand}" Style="{StaticResource SecondaryButton}"/>
                <Button Content="Export Excel" Command="{Binding ExportExcelCommand}" Style="{StaticResource SecondaryButton}"/>
                <Button Content="Export JSON" Command="{Binding ExportJsonCommand}" Style="{StaticResource SecondaryButton}"/>
                <Button Content="Copy Summary" Command="{Binding CopySummaryCommand}" Style="{StaticResource SecondaryButton}"/>
                <Button Content="Open Folder" Command="{Binding OpenFolderCommand}" Style="{StaticResource SecondaryButton}"/>
            </StackPanel>
        </Border>

        <!-- Bottom Buttons -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Execute Action" Command="{Binding ExecuteCommand}" Style="{StaticResource PrimaryButton}" Width="150"/>
        </Grid>
    </Grid>
</Window>
